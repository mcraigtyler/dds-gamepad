{
    "configurations": [
        {
            "name": "DevContainer",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/build",
                "${workspaceFolder}/install/cyclonedds/include",
                "${workspaceFolder}/install/cyclonedds-cxx/include/ddscxx"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE"
            ],
            "cStandard": "c17",
            "cppStandard": "c++20",
            "intelliSenseMode": "gcc-x64",
            "compilerPath": "/usr/bin/gcc"
        },
        {
            "name": "Windows",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/build",
                "${workspaceFolder}/install/cyclonedds/include",
                "${workspaceFolder}/install/cyclonedds-cxx/include/ddscxx",
                "${workspaceFolder}/build/vcpkg_installed/x64-windows/include"
            ],
            "defines": [
                "_DEBUG",
                "WIN32",
                "_WINDOWS",
                "NOMINMAX",
                "WIN32_LEAN_AND_MEAN",
                "_USE_MATH_DEFINES"
            ],
            "cStandard": "c17",
            "cppStandard": "c++20",
            "intelliSenseMode": "msvc-x64",
            "compilerPath": "cl.exe"
        }
    ],
    "version": 4
}
